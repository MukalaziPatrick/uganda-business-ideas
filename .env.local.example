# Supabase local development values.
# Copy these keys into .env.local and fill the values locally.
# Do not commit real secret values.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# WhatsApp Bot (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=        # from Meta Business dashboard → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=           # Meta permanent access token
WHATSAPP_VERIFY_TOKEN=mukalazi_verify_2026   # must match what you enter in Meta webhook settings

# Telegram Bot (for Patrick's approval notifications)
TELEGRAM_BOT_TOKEN=              # from @BotFather on Telegram
TELEGRAM_CHAT_ID=                # message @userinfobot on Telegram to get your ID

# OpenRouter (already set — shared with other features)
# OPENROUTER_API_KEY=
